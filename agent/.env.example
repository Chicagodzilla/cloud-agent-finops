# 阿里云百炼 API Key，用于 LLM 和 Embedding
DASHSCOPE_API_KEY=your_dashscope_api_key

# 可选：模型与兼容 OpenAI 的调用地址
MODEL=qwen-plus
BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Redis 配置，用于短期记忆；本地演示可不配置
REDIS_URL=redis://localhost:6379
REDIS_TTL=1800

# Milvus 配置，用于长期记忆和语义缓存；本地演示可不配置
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_API_KEY=

# MySQL 配置，用于云资源、订单、监控 mock 数据
# 本地开源演示默认使用 Mock 模式；设为 false 后才会连接 MySQL
MOCK_DATA_MODE=true
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=cloud_platform

# Neo4j 配置，用于知识图谱检索；本地演示可不配置
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password
NEO4J_DATABASE=neo4j

# 日志级别
LOG_LEVEL=INFO
